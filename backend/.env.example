# LLM provider: gemini_kie | claude | mock (offline stub for dev/testing)
LLM_PROVIDER=gemini_kie

# kie.ai Gemini 3.1 Pro
KIE_API_KEY=
KIE_BASE_URL=https://api.kie.ai/gemini-3.1-pro/v1
KIE_MODEL=gemini-3.1-pro

# Claude (optional fallback)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# Storage
UPLOAD_DIR=./storage/uploads
OUTPUT_DIR=./storage/outputs

# CORS (frontend origin)
FRONTEND_ORIGIN=http://localhost:3000
