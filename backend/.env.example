# Default LLM provider: gemini_kie | claude | deepseek | mock
# Used when the frontend does NOT send a per-request `model` field.
LLM_PROVIDER=gemini_kie

# kie.ai Gemini 3.1 Pro
KIE_API_KEY=
KIE_BASE_URL=https://api.kie.ai/gemini-3.1-pro/v1
KIE_MODEL=gemini-3.1-pro

# Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# DeepSeek (models: deepseek-v4-flash, deepseek-v4-pro)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Storage
UPLOAD_DIR=./storage/uploads
OUTPUT_DIR=./storage/outputs

# CORS (frontend origin)
FRONTEND_ORIGIN=http://localhost:3000
